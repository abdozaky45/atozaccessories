{
  "info": {
    "name": "A to Z Accessories - Sizes",
    "description": "Full CRUD endpoints for the Sizes resource (admin only).\n\nBase path: /admin/sizes\nAuth: Bearer token (Admin role required).\n\nSet the collection/environment variables:\n- baseUrl: e.g. http://localhost:3000\n- token: a valid admin JWT access token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "sizeId", "value": "" }
  ],
  "item": [
    {
      "name": "Create Size",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"number\": \"42\",\n  \"order\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/sizes",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "sizes"]
        }
      }
    },
    {
      "name": "List Sizes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/sizes?page=1",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "sizes"],
          "query": [{ "key": "page", "value": "1" }]
        }
      }
    },
    {
      "name": "Get Size By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/sizes/{{sizeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "sizes", "{{sizeId}}"]
        }
      }
    },
    {
      "name": "Update Size",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"number\": \"43\",\n  \"order\": 4\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/sizes/{{sizeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "sizes", "{{sizeId}}"]
        }
      }
    },
    {
      "name": "Delete Size",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/sizes/{{sizeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "sizes", "{{sizeId}}"]
        }
      }
    }
  ]
}
