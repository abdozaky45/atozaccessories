{
  "info": {
    "name": "Icons Admin API",
    "description": "Admin icon endpoints mounted under /admin/icons. All requests require an ADMIN Bearer token ({{token}}).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "iconId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List Icons",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/icons?page=1",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "icons"],
          "query": [
            { "key": "page", "value": "1" }
          ]
        },
        "description": "Paginated list of icons (20 per page). page defaults to 1 when omitted or invalid."
      }
    },
    {
      "name": "Get Icon By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/icons/{{iconId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "icons", "{{iconId}}"]
        },
        "description": "Get a single icon by id."
      }
    },
    {
      "name": "Create Icon",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"key\": \"facebook\",\n  \"svg\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\"></svg>\",\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/icons",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "icons"]
        },
        "description": "Create a new icon. key must be unique; isActive defaults to true. Responds with status 200."
      }
    },
    {
      "name": "Update Icon",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"key\": \"facebook\",\n  \"svg\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\"></svg>\",\n  \"isActive\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/icons/{{iconId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "icons", "{{iconId}}"]
        },
        "description": "Update an icon. Only changed fields are applied. If key changes it must not collide with an existing icon."
      }
    },
    {
      "name": "Delete Icon",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/icons/{{iconId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "icons", "{{iconId}}"]
        },
        "description": "Permanently delete an icon. Detaches it from any categories (sets their icon_id to null)."
      }
    }
  ]
}
