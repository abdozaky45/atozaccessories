            ],
            "url": { "raw": "{{baseUrl}}/admin/sizes/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "sizes", ":_id"], "variable": [{ "key": "_id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"L\",\n  \"order\": 3\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Size",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/sizes/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "sizes", ":_id"], "variable": [{ "key": "_id", "value": "" }] }
          }
        }
      ]
    },

    {
      "name": "Admin — Offers",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/offers. Agenda job scheduling for the timed offer (flash_sale). Cart offers (one applied per order, most valuable to the customer): buy_x_get_cheapest_free, spend_x_get_discount, spend_x_get_free_shipping, buy_x_get_free_shipping, buy_x_get_half_price, spend_x_get_free_item. Homepage/flash offer: flash_sale (product-targeted, time-bounded).",
      "item": [
        {
          "name": "List Offers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/offers?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "offers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "offerType", "value": "", "disabled": true, "description": "buy_x_get_cheapest_free | spend_x_get_discount | spend_x_get_free_shipping | buy_x_get_free_shipping | buy_x_get_half_price | spend_x_get_free_item | flash_sale" },
                { "key": "isActive", "value": "", "disabled": true, "description": "true | false" }
              ]
            }
          }
        },
        {
          "name": "Get Offer by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/offers/:id", "host": ["{{baseUrl}}"], "path": ["admin", "offers", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Returns offer with condition.excludedCategories, targetProducts, and targetCategories all populated."
          }
        },
        {
          "name": "Create Offer — buy_x_get_cheapest_free",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/offers", "host": ["{{baseUrl}}"], "path": ["admin", "offers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy 3 Get Cheapest Free\",\n  \"description\": \"Add 3 items and the cheapest one is on us\",\n  \"isActive\": true,\n  \"image\": { \"mediaUrl\": \"https://atozaccessories.s3.amazonaws.com/offers/buy3free\" },\n  \"offerType\": \"buy_x_get_cheapest_free\",\n  \"condition\": { \"minQuantity\": 3, \"minAmount\": null, \"excludedCategories\": [] },\n  \"reward\": { \"discountPercentage\": null, \"freeItemMaxValue\": null },\n  \"targetProducts\": [],\n  \"targetCategories\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Buy N items (minQuantity); the price of one cheapest item is applied as an order-level discount."
          }
        },
        {
          "name": "Create Offer — spend_x_get_discount",
          "request": {
            "method": "POST",
            "header": [
