{
  "info": {
    "_postman_id": "a2z-accessories-admin-v1",
    "name": "A-to-Z Accessories API — Admin",
    "description": "Admin-only collection. Contains every ADMIN-protected endpoint (routers mounted behind checkRole([ADMIN])) plus the Authentication flow used by admins to obtain an access token.\n\nAdmin route groups: /admin/categories, /admin/products, /admin/icons, /admin/colors, /admin/sizes, /admin/offers, /admin/orders, /slider, /aws.\n\nSet the `token` variable to the admin accessToken returned by Activate Account.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Authentication (Admin Login)",
      "description": "Public — no auth required. Admin login uses an OTP flow: register-email sends a 6-digit code, active-account validates it and returns the accessToken.",
      "item": [
        {
          "name": "Register / Login with Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/authentication/register-email", "host": ["{{baseUrl}}"], "path": ["authentication", "register-email"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates account if new. If user is ADMIN, sends 6-digit OTP via email."
          }
        },
        {
          "name": "Activate Account (Admin OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/authentication/active-account", "host": ["{{baseUrl}}"], "path": ["authentication", "active-account"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"activeCode\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Validates the 6-digit OTP (valid 15 min). Returns accessToken on success — copy it into the `token` collection variable."
          }
        },
        {
          "name": "Resend Activation Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/authentication/email-new-code", "host": ["{{baseUrl}}"], "path": ["authentication", "email-new-code"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Generates and emails a fresh 6-digit OTP."
          }
        }
      ]
    },

    {
      "name": "Admin — Categories",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/categories.",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/categories", "host": ["{{baseUrl}}"], "path": ["admin", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Rings\",\n  \"imageUrl\": \"https://atozaccessories.s3.amazonaws.com/categories/example.jpg\",\n  \"icon_id\": \"<iconId>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "icon_id is optional. If provided, it must reference an existing Icon document."
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/categories/:id", "host": ["{{baseUrl}}"], "path": ["admin", "categories", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Updated Rings\",\n  \"imageUrl\": \"https://atozaccessories.s3.amazonaws.com/categories/new.jpg\",\n  \"icon_id\": \"<iconId>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "All fields optional. icon_id, if provided, must reference an existing Icon document."
          }
        },
        {
          "name": "Soft Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/categories/:id", "host": ["{{baseUrl}}"], "path": ["admin", "categories", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Marks category as isDeleted: true."
          }
        },
        {
          "name": "Hard Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/categories/:id/hard", "host": ["{{baseUrl}}"], "path": ["admin", "categories", ":id", "hard"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Permanently deletes the category, its products, variants, and their S3 images."
          }
        },
        {
          "name": "Get All Categories (shared)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/public/category/get-all-categories", "host": ["{{baseUrl}}"], "path": ["public", "category", "get-all-categories"] },
            "description": "Public — no auth required. Shared read endpoint used by both users and admins. Returns all non-deleted categories with icon_id populated."
          }
        },
        {
          "name": "Get Category by ID (shared)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/public/category/get-one-category/:categoryId", "host": ["{{baseUrl}}"], "path": ["public", "category", "get-one-category", ":categoryId"], "variable": [{ "key": "categoryId", "value": "" }] },
            "description": "Public — no auth required. Shared read endpoint used by both users and admins. Returns a single category with icon_id populated. 404 if soft-deleted."
          }
        }
      ]
    },

    {
      "name": "Admin — Products",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/products.",
      "item": [
        {
          "name": "Get Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/products/analysis", "host": ["{{baseUrl}}"], "path": ["admin", "products", "analysis"] },
            "description": "Returns totalRevenue (delivered orders), totalOrders, totalCustomers, totalProducts."
          }
        },
        {
          "name": "Get Admin Products List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/products?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products"],
              "query": [
                { "key": "category", "value": "", "disabled": true },
                { "key": "isBestSeller", "value": "", "disabled": true },
                { "key": "isSale", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true },
                { "key": "color", "value": "", "disabled": true },
                { "key": "size", "value": "", "disabled": true },
                { "key": "isDeleted", "value": "", "disabled": true, "description": "true | false — admin can see deleted products" },
                { "key": "sort", "value": "", "disabled": true, "description": "price | soldItems | createdAt" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Admin product list — includes isDeleted filter. Uses unified filter logic."
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/products", "host": ["{{baseUrl}}"], "path": ["admin", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Gold Ring\",\n  \"productDescription\": \"18k gold ring with diamond\",\n  \"price\": 1200,\n  \"availableItems\": 50,\n  \"categoryId\": \"<categoryId>\",\n  \"defaultImage\": \"https://atozaccessories.s3.amazonaws.com/products/ring.jpg\",\n  \"salePrice\": 999,\n  \"albumImages\": [\n    \"https://atozaccessories.s3.amazonaws.com/products/ring2.jpg\"\n  ],\n  \"wholesalePrice\": 600,\n  \"isBestSeller\": false,\n  \"variants\": [\n    { \"color\": \"<colorId>\", \"size\": \"<sizeId>\", \"availableItems\": 10 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Includes wholesalePrice, auto-computed finalPrice, and variants array. isSale is auto-derived from salePrice < price."
          }
        },
        {
          "name": "Get Admin Product by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["admin", "products", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Returns product with variants populated. Includes wholesalePrice (admin only)."
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["admin", "products", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Updated Gold Ring\",\n  \"productDescription\": \"Updated description\",\n  \"price\": 1300,\n  \"availableItems\": 45,\n  \"categoryId\": \"<categoryId>\",\n  \"defaultImage\": \"https://atozaccessories.s3.amazonaws.com/products/ring_new.jpg\",\n  \"salePrice\": 1100,\n  \"albumImages\": [\n    \"https://atozaccessories.s3.amazonaws.com/products/ring_new2.jpg\"\n  ],\n  \"wholesalePrice\": 650,\n  \"isBestSeller\": true,\n  \"variants\": [\n    { \"_id\": \"<existingVariantId>\", \"color\": \"<colorId>\", \"size\": \"<sizeId>\", \"availableItems\": 8 },\n    { \"color\": \"<colorId2>\", \"size\": \"<sizeId2>\", \"availableItems\": 12 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "finalPrice recomputed on every update. isSale auto-derived. Setting isBestSeller: true also sets bestSellerManual: true so the cron job does not override this product. Variants upserted: _id present → update, else → create."
          }
        },
        {
          "name": "Hard Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/products/:id/hard", "host": ["{{baseUrl}}"], "path": ["admin", "products", ":id", "hard"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Permanently deletes product: removes defaultImage and albumImages from S3, deletes all variants, then removes DB record."
          }
        },
        {
          "name": "Delete Product Variant",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/products/:productId/variants/:variantId", "host": ["{{baseUrl}}"], "path": ["admin", "products", ":productId", "variants", ":variantId"], "variable": [{ "key": "productId", "value": "" }, { "key": "variantId", "value": "" }] },
            "description": "Hard-deletes a single product variant by its ID."
          }
        },
        {
          "name": "Soft Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/products/:id", "host": ["{{baseUrl}}"], "path": ["admin", "products", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Sets isDeleted: true on the product."
          }
        }
      ]
    },

    {
      "name": "Admin — Icons",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/icons.",
      "item": [
        {
          "name": "List Icons",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/icons?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "icons"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Icon by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/icons/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "icons", ":_id"], "variable": [{ "key": "_id", "value": "" }] }
          }
        },
        {
          "name": "Create Icon",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/icons", "host": ["{{baseUrl}}"], "path": ["admin", "icons"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"ring-icon\",\n  \"svg\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\"><circle cx=\\\"12\\\" cy=\\\"12\\\" r=\\\"10\\\"/></svg>\",\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "key must be unique. svg is the raw SVG string."
          }
        },
        {
          "name": "Update Icon",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/icons/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "icons", ":_id"], "variable": [{ "key": "_id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"ring-icon-v2\",\n  \"svg\": \"<svg xmlns=\\\"http://www.w3.org/2000/svg\\\" viewBox=\\\"0 0 24 24\\\"><path d=\\\"M12 2L2 22h20z\\\"/></svg>\",\n  \"isActive\": false\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Icon",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/icons/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "icons", ":_id"], "variable": [{ "key": "_id", "value": "" }] },
            "description": "Deletes the icon and nulls out icon_id on any categories referencing it."
          }
        }
      ]
    },

    {
      "name": "Admin — Colors",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/colors.",
      "item": [
        {
          "name": "List Colors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/colors?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "colors"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "search", "value": "", "disabled": true, "description": "Optional name search" }
              ]
            }
          }
        },
        {
          "name": "Get Color by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/colors/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "colors", ":_id"], "variable": [{ "key": "_id", "value": "" }] }
          }
        },
        {
          "name": "Create Color",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/colors", "host": ["{{baseUrl}}"], "path": ["admin", "colors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gold\",\n  \"hex\": \"#FFD700\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "name must be unique. hex must be a valid CSS hex color (e.g. #FFD700 or #F5C)."
          }
        },
        {
          "name": "Update Color",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/colors/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "colors", ":_id"], "variable": [{ "key": "_id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rose Gold\",\n  \"hex\": \"#B76E79\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Color",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/colors/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "colors", ":_id"], "variable": [{ "key": "_id", "value": "" }] }
          }
        }
      ]
    },

    {
      "name": "Admin — Sizes",
      "description": "Requires Bearer token. Role: ADMIN only. Mounted at /admin/sizes.",
      "item": [
        {
          "name": "List Sizes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/sizes?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "sizes"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Size by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/admin/sizes/:_id", "host": ["{{baseUrl}}"], "path": ["admin", "sizes", ":_id"], "variable": [{ "key": "_id", "value": "" }] }
          }
        },
        {
